# PostgreSQL connection (with pgvector extension enabled)
# Use the pgvector/pgvector Docker image: docker run -d --name postgres-alt \
#   -e POSTGRES_DB=alternative_history -e POSTGRES_USER=user \
#   -e POSTGRES_PASSWORD=password -p 5432:5432 pgvector/pgvector:pg17
DATABASE_URL=postgresql://user:password@localhost:5432/alternative_history

# Anthropic API key — used for generating alternative news articles (Claude Opus 4.6)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used only for generating text embeddings (text-embedding-3-small)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# The Guardian Open Platform API key — used to fetch real-world historical news
# Free tier: 12 req/s, full historical archive back to 1999
# Get one at: https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=...
